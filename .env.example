# Copy this file to .env and fill in your values
# Never commit .env — it is gitignored

# Optional: Microsoft Planetary Computer subscription key
# Free account at https://planetarycomputer.microsoft.com/ → higher rate limits for NAIP fetch
PC_SDK_SUBSCRIPTION_KEY=

# Required for M3: VLM helipad bounding-box validation (Claude vision API)
ANTHROPIC_API_KEY=

# Required for M3: FAA live NOTAM feed
FAA_API_KEY=

# Required for M4: TomTom Routing API (traffic-aware ground routes)
# Free: 2,500 calls/day, NO credit card required
# Register at https://developer.tomtom.com/ (email only)
TOMTOM_API_KEY=

# Required for M4: Groq LLM API (Route Assistant natural language interface)
# Free tier: ~14,400 req/day with Llama-3.3-70b-versatile
# Register at https://console.groq.com/ (email only, no credit card)
GROQ_API_KEY=

# Optional: Mapillary API access token (street-level imagery in booking flow)
# Free: unlimited read access, no credit card
# Register at https://www.mapillary.com/dashboard/developers → "Create Application"
# Copy the "Client Token" (starts with MLY|...)
MAPILLARY_TOKEN=

# Required for M4: Mapbox traffic flow overlay (green/yellow/red roads on all maps)
# Free: 50,000 map loads/month, NO credit card required
# Register at https://account.mapbox.com/ (email only)
# Copy the default public token from your account dashboard (starts with pk.eyJ1...)
MAPBOX_TOKEN=

# Optional: Google Earth Engine (future phase)
GEE_PROJECT_ID=
